{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"target": "ES2023",
		"module": "ESNext",
		"lib": ["ES2023"],
		"types": ["node"],
		"strict": true,
		"noUncheckedSideEffectImports": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules"]
}
